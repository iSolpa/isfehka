<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="payment_provider_view_form_inherit_isfehka" model="ir.ui.view">
        <field name="name">payment.provider.form.inherit.isfehka</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='company_id']" position="after">
                <field name="hka_payment_type" string="HKA Payment Type"
                       help="Map this payment provider to HKA payment type for electronic invoicing"/>
            </xpath>
        </field>
    </record>
</odoo>
